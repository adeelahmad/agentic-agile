{
  "hooks": {
    "WorktreeCreate": [
      { "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/worktree-create", "timeout": 60 } ] }
    ],
    "WorktreeRemove": [
      { "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/worktree-remove", "timeout": 30 } ] }
    ],
    "PreToolUse": [
      { "matcher": "Write|Edit|MultiEdit|NotebookEdit", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-supervisor-scope" } ] }
    ],
    "UserPromptSubmit": [
      { "matcher": "*", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/transcripts prompt" } ] }
    ],
    "SubagentStart": [
      { "matcher": "red-worker|scaffolder|green-worker|structural-reviewer|final-gate", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-tooling" } ] },
      { "matcher": "*", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/transcripts stage-in" } ] }
    ],
    "PostToolUse": [
      { "matcher": "Write", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-validate-artifact" } ] },
      { "matcher": "*", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/transcripts record" } ] }
    ],
    "Stop": [
      { "matcher": "*", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/transcripts snapshot" } ] }
    ],
    "SubagentStop": [
      { "matcher": "intake", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-intake" } ] },
      { "matcher": "standards", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-standards-cited" } ] },
      { "matcher": "planner", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-stage2-complete" } ] },
      { "matcher": "archivist", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-memory" } ] },
      { "matcher": "red-worker", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-red-verify" } ] },
      { "matcher": "scaffolder", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-scaffold-verify" } ] },
      { "matcher": "green-worker", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-green-verify" } ] },
      { "matcher": "structural-reviewer", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-structural-integrity" } ] },
      { "matcher": "final-gate", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/gate-final" } ] },
      { "matcher": "*", "hooks": [
        { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/transcripts stop" } ] }
    ]
  }
}
