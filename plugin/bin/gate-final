#!/usr/bin/env bash
# FINAL GATE (sprint sign-off): full standards matrix green, zero suppressions,
# every plan-ready.md fully [x]. (Target: Rust; matrix from standards.md.)
GATE_NAME="gate-final"
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
: "${CLAUDE_PLUGIN_ROOT:=$(cd "$HERE/.." && pwd)}"
# shellcheck source=/dev/null
source "$HERE/_gatelib.sh"

root="$(repo_dir)"

# 1) Zero suppressions anywhere.
assert_no_suppression

# 2) Every plan-ready.md fully ticked.
if grep -rl '\- \[ \]' --include='plan-ready.md' "$root" 2>/dev/null | grep -q .; then
  fail "an unticked plan-ready.md box remains (sprint not GREEN-complete)"
fi

# 3) Full gate matrix (from standards.md) green.
run_standards_matrix

note "FINAL gate passed: matrix green, zero suppressions, all plan-ready ticked"
exit 0
